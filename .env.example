# Sovereign RAG Configuration Template
# Copy this file to '.env' and fill in your keys.

# Your Google Gemini API Key
# If set, the app will use Gemini for embeddings (text-embedding-004) and LLM (gemini-1.5-flash)
GEMINI_API_KEY=your_gemini_api_key_here

# Your OpenAI API Key (alternative)
OPENAI_API_KEY=

# Note: If both are left blank, the app will fall back to local sentence-transformers (all-MiniLM-L6-v2) for embeddings

# Backend configuration (optional)
PORT=8000
HOST=127.0.0.1

